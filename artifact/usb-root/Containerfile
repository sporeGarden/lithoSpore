# lithoSpore — OCI container image for cross-OS validation.
#
# Runs the full validation suite (Tier 1 + 2) inside a container.
# Works on any OS with Docker, Podman, or Singularity.
#
# Build from the USB artifact root:
#   docker build -f Containerfile -t litho-spore .
#   podman build -f Containerfile -t litho-spore .
#
# Run:
#   docker run litho-spore                           # default: validate
#   docker run litho-spore validate --max-tier 1     # Python only
#   docker run litho-spore verify                    # BLAKE3 integrity
#   docker run litho-spore self-test                 # artifact checks
#   docker run --network=none litho-spore            # airgap simulation
#
# Interactive:
#   docker run -it --entrypoint /bin/bash litho-spore

FROM docker.io/library/ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-numpy python3-scipy python3-matplotlib \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY . /opt/lithoSpore

WORKDIR /opt/lithoSpore

ENTRYPOINT ["/opt/lithoSpore/bin/litho"]
CMD ["validate", "--artifact-root", "/opt/lithoSpore"]
