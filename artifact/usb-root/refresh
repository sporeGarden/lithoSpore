#!/bin/sh
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# refresh — re-fetch datasets from source URIs and re-validate BLAKE3 hashes.
#
# Requires network access. Reads data_manifest.toml for source URIs and
# refresh commands. Updates BLAKE3 hashes in-place.
#
# Usage:
#   ./refresh                   Re-fetch all datasets
#   ./refresh --dry-run         Show what would be fetched

set -e

SPORE_ROOT="$(cd "$(dirname "$0")" && pwd)"
LITHO="$SPORE_ROOT/bin/litho"

if [ -f "$LITHO" ] && [ -x "$LITHO" ]; then
    exec "$LITHO" refresh --artifact-root "$SPORE_ROOT" "$@"
fi

echo "lithoSpore refresh: Rust binary not found at $LITHO"
echo "  Refresh requires the litho ecoBin binary."
echo "  Manual refresh: run the fetch scripts in scripts/ from the source repo."
exit 1
