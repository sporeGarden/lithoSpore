#!/bin/sh
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# verify — lithoSpore data integrity and upstream source check
#
# Verifies every bundled data file against its BLAKE3 hash in
# data_manifest.toml. When online, also probes upstream source
# URIs (databases, repositories) for reachability.
#
# Usage:
#   ./verify               Human-readable output
#   ./verify --json         Structured JSON output
#
# Exit codes:
#   0   All files intact, no drift detected
#   1   At least one file has drifted from its manifest hash

set -e

SPORE_ROOT="$(cd "$(dirname "$0")" && pwd)"
LITHO="$SPORE_ROOT/bin/litho"

if [ -f "$LITHO" ] && [ -x "$LITHO" ]; then
    exec "$LITHO" verify --artifact-root "$SPORE_ROOT" "$@"
fi

echo "ERROR: litho binary not found at $LITHO"
echo "  Cannot verify without the litho CLI."
exit 1
